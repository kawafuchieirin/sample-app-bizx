*.dec
*.decrypted
*.plaintext
age-key.txt
keys.txt

# sops-managed secret files are safe to commit after encryption.
!.env.sops
!.env.sops.example
!*.env.sops
!*.sops.env
!*.sops.yaml
!*.sops.yml

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp
