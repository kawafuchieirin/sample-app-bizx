# Template for the encrypted backend environment file.
# Create apps/backend/.env.sops from this file, fill real values, then run:
#   mise x sops@latest -- sops --encrypt --in-place apps/backend/.env.sops

BIZX_TABLE_NAME=bizx-tasks
BIZX_AWS_REGION=ap-northeast-1
BIZX_DYNAMODB_ENDPOINT_URL=
BIZX_COGNITO_USER_POOL_ID=
BIZX_COGNITO_CLIENT_ID=
BIZX_CORS_ORIGINS=http://localhost:5173
BIZX_AUTH_DISABLED=false
