# Copy to .env for local development. Never commit real secrets.

# DynamoDB
BIZX_TABLE_NAME=bizx-tasks
BIZX_AWS_REGION=ap-northeast-1
# Point at a local DynamoDB (e.g. docker) during development:
# BIZX_DYNAMODB_ENDPOINT_URL=http://localhost:8000

# Cognito (required when BIZX_AUTH_DISABLED=false)
BIZX_COGNITO_USER_POOL_ID=
BIZX_COGNITO_CLIENT_ID=

# CORS (comma-separated origins)
BIZX_CORS_ORIGINS=http://localhost:5173

# Local-only: skip JWT signature verification and trust the token's `sub`.
# MUST remain false in any deployed environment.
BIZX_AUTH_DISABLED=true
