# Copy to .env.local and fill from `terraform output` (infra/terraform/aws).

# OIDC issuer — cognito_issuer output.
VITE_COGNITO_AUTHORITY=https://cognito-idp.ap-northeast-1.amazonaws.com/ap-northeast-1_XXXXXXXXX
# cognito_client_id output.
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Hosted UI domain — cognito_hosted_ui_domain output (used for sign-out).
VITE_COGNITO_DOMAIN=bizx-dev-xxxx.auth.ap-northeast-1.amazoncognito.com

# Where Cognito redirects back after login/logout. Must match the Terraform
# callback_urls / logout_urls (default http://localhost:5173/).
VITE_REDIRECT_URI=http://localhost:5173/

# Backend API base URL.
VITE_API_BASE_URL=http://localhost:8000/api/v1
